NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key — required for server-side role management (bypasses RLS)
# Get it from: Supabase Dashboard > Project Settings > API > service_role key
# WARNING: Never expose this key client-side (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Afficher les comptes de démo sur la page de connexion (dev uniquement)
# Mettre à "false" ou supprimer en production
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=false

# ARCHIVÉ : Moko Afrika Config (Remplacé par PawaPay)
# MOKO_API_BASE_URL=https://paydrc.gofreshbakery.net
# MOKO_MERCHANT_ID=your_merchant_id
# MOKO_MERCHANT_SECRET=your_merchant_secret
# MOKO_CARD_API_KEY=your_moko_card_api_key
# MOKO_CARD_API_SECRET=your_moko_card_api_secret
# MOKO_CARD_API_URL=https://test.card.gofreshpay.com/api/v1/payment/orders

# PawaPay Sandbox Configuration
PAWAPAY_API_TOKEN=your_pawapay_sandbox_api_token_here

# Public application URL for webhooks
NEXT_PUBLIC_APP_URL=https://ansella.app

# Gemini API Key for AI Course & Lesson Generation
GEMINI_API_KEY=your_gemini_api_key

# Email Dispatcher Configuration (Resend, Brevo, SendGrid, Postmark)
# Configure one of the providers to send real emails to students and instructors
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=Ansella Academy <notifications@ansella.app>
# BREVO_API_KEY=your_brevo_api_key
# SENDGRID_API_KEY=your_sendgrid_api_key
# POSTMARK_SERVER_TOKEN=your_postmark_token



